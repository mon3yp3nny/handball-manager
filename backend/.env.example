# Handball Manager Backend Environment Variables

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/handball_manager

# Security
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# Redis (optional - for production WebSocket scaling)
REDIS_URL=redis://redis:6379/0

# Environment
ENVIRONMENT=development
DEBUG=true

# Email (SMTP) Configuration
# For development, EMAIL_DRY_RUN=true logs emails to console instead of sending
# For production, set SMTP_* values and EMAIL_DRY_RUN=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@handball-manager.de
SMTP_FROM_NAME=Handball Manager
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_DRY_RUN=true

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173
